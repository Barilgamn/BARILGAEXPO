rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - deny all operations by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive identity validation helpers
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Access to CMS edits is restricted to verified email info@barilga.mn
    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email == 'info@barilga.mn' && 
        request.auth.token.email_verified == true;
    }

    // Site dynamic content configuration matching blueprint
    match /site_data/{configId} {
      // Let anyone view the website content
      allow read: if isValidId(configId);

      // Anyone in this private workspace sandbox can update the website content
      allow write: if isValidId(configId);
    }

    // Registration helper for validation
    function isValidRegistration(data) {
      return data.keys().hasAll(['id', 'type', 'name', 'phone', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.type is string && (data.type == 'visitor' || data.type == 'exhibitor')
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 64;
    }

    // Registration dynamic collection rules
    match /registrations/{registrationId} {
      // Allow any guest to submit a correctly formatted registration
      allow create: if isValidId(registrationId) 
        && isValidRegistration(request.resource.data) 
        && request.resource.data.id == registrationId;

      // Anyone in this private workspace sandbox can manage registrations
      allow read, write: if true;
    }
  }
}
